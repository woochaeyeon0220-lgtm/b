{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "u": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "r": {
          "$id": {
            ".validate": "newData.hasChildren(['n', 'd']) && newData.child('n').isString() && newData.child('n').val().length <= 50 && newData.child('d').isString() && newData.child('d').val().length <= 10"
          }
        }
      }
    },

    "n": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$id": {
        ".validate": "newData.hasChildren(['t', 'c'])"
      }
    }
  }
}
